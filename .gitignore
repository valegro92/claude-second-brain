# ═══════════════════════════════════════════════
# Sistema
# ═══════════════════════════════════════════════

# macOS
.DS_Store
*.DS_Store

# Obsidian
.obsidian/
.trash/

# Claude config personale
.claude/

# ═══════════════════════════════════════════════
# Python (toolkit Step 2)
# ═══════════════════════════════════════════════

__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
dist/
build/

# ═══════════════════════════════════════════════
# Runtime del toolkit (dati cliente — MAI in git)
# ═══════════════════════════════════════════════

# Output del pipeline: inventory, extracted, drafts, audit, cost log
_status/

# Cartella di input per il file watcher (drop zone)
_inbox/

# Config cliente con credenziali
bootstrap/clients/
bootstrap/auth/.*-token.json
bootstrap/auth/credentials.json
bootstrap/auth/service-account-*.json

# ═══════════════════════════════════════════════
# Vault: privacy per vault realmente in uso
# (NON applicabile al template `vault/_esempio/`)
# ═══════════════════════════════════════════════

# Journal personali (uno per persona)
vault/Daily/*/
!vault/Daily/_esempio-XX/

# Config locale utente attivo (in CLAUDE.md, sezione [UTENTE LOCALE])
# Nota: se vault è git-condiviso, ogni utente DEVE avere il suo CLAUDE.md locale
# non versionato. Per ora il vault del repo è template, quindi CLAUDE.md è in git.

# ═══════════════════════════════════════════════
# Binari (mai nel vault)
# ═══════════════════════════════════════════════

*.docx
*.pptx
*.xlsx
*.pdf
*.bak
*.tmp

# ═══════════════════════════════════════════════
# Custodia v2 — runtime state e credenziali
# ═══════════════════════════════════════════════

# State store SQLite di ogni progetto cliente — MAI in git
.custodia-state/

# Workspace metadata + project list (utente-specifico)
.custodia/

# Token cache OAuth (Google Drive, Microsoft Graph, Fatture in Cloud)
google_token.json
microsoft_token.json
fic_token.json
*.oauth-token.json

# Credentials desktop OAuth (devono essere fornite dal consulente, non committed)
custodia-credentials.json
*credentials.json

# Cache raw bytes dei connettori (Drive/Outlook export download)
cache/

# Output transitori demo onboarding (rigenerati da record_demo.py)
docs/onboarding-screenshots/frames/

# Streamlit secrets/cache
.streamlit/secrets.toml
